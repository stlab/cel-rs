        // ============ Sanitizers - Windows ============
        // NOTE: AddressSanitizer support on Windows is experimental and limited.
        // For reliable memory testing, use WSL2, macOS, or Linux.
        {
            "label": "cargo test (Windows - comprehensive)",
            "type": "cargo",
            "command": "test",
            "args": [
                "--workspace",
                "--all-targets"
            ],
            "options": {
                "env": {
                    "RUST_BACKTRACE": "1"
                }
            },
            "problemMatcher": [
                "$rustc"
            ]
        },
        {
            "label": "sanitizer: address (Windows - experimental)",
            "type": "shell",
            "command": "cargo",
            "args": [
                "+nightly",
                "test",
                "-Zbuild-std",
                "--target",
                "x86_64-pc-windows-msvc",
                "--workspace"
            ],
            "options": {
                "env": {
                    "RUST_BACKTRACE": "1",
                    "RUSTFLAGS": "-Zsanitizer=address",
                    "RUSTDOCFLAGS": "-Zsanitizer=address"
                }
            },
            "problemMatcher": [
                "$rustc"
            ],
