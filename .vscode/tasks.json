                "-Zbuild-std",
                "--target",
                "x86_64-pc-windows-msvc",
                "--lib",
                "--workspace"
            ],
            "options": {
                "env": {
                    "RUST_BACKTRACE": "1",
                    "RUSTFLAGS": "-Zsanitizer=address -Clink-arg=/wholearchive:clang_rt.asan-x86_64.lib"
                }
            },
            "problemMatcher": [
                "$rustc"
            ],
            "presentation": {
